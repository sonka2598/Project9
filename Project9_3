void writeMus(int *mus, int size)
{
   for (int i = 0; i < size; i++)
   {
       std::cout << mus[i] << " ";
   }
   std::cout << std::endl;
}

void reverse(int *mus, int size)
{
   std::cout << "До функции reverse: ";
   writeMus(mus, size);

   for (int i = 0; i < size / 2; ++i) {
       int temp = mus[i];
       mus[i] = mus[size - 1 - i];
       mus[size - 1 - i] = temp;
   }

   std::cout << "После функции reverse: ";
   writeMus(mus, size);
}

